---
interface Article {
  id: string;
  data: {
    title: string;
    category: string;
    publishedAt: Date;
    description: string;
  };
}

interface Props {
  articles: Article[];
  title?: string;
}

const { articles, title = '📖 Articles liés' } = Astro.props;
---

<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
  <div class="px-4 py-3 border-b border-slate-100">
    <p class="font-semibold text-slate-800 text-sm">{title}</p>
  </div>

  <ul class="divide-y divide-slate-100">
    {articles.map((a) => (
      <li>
        <a href={`/guide/${a.id}`} class="flex items-start gap-3 px-4 py-3 hover:bg-slate-50 transition-colors group">
          <div class="flex-shrink-0 w-1 h-full self-stretch">
            <div class="w-1 h-8 rounded-full bg-brand-200 group-hover:bg-brand-500 transition-colors mt-0.5"></div>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-slate-800 group-hover:text-brand-600 transition-colors line-clamp-2 leading-snug">
              {a.data.title}
            </p>
            <p class="text-xs text-slate-400 mt-1">{a.data.category}</p>
          </div>
        </a>
      </li>
    ))}
  </ul>

  <div class="px-4 py-3 text-center border-t border-slate-100">
    <a href="/guide" class="text-xs text-brand-600 hover:underline">
      Tous les guides →
    </a>
  </div>
</div>
