    });
  }

  function setProgress(pct) {
    var bar = document.getElementById("diag-progress");
    if (bar) bar.style.width = pct + "%";
  }

  // ── Rendu dynamique de l'étape 2 ────────────────────────────────────────

  function renderStep2(objectif) {
    var opts = situations[objectif];
    if (!opts) return;
    var container = document.getElementById("step-2-options");
    if (!container) return;
    container.innerHTML = "";
    opts.forEach(function (o) {
      var btn = document.createElement("button");
      btn.type = "button";
      btn.setAttribute("data-step", "2");
      btn.setAttribute("data-val", o.val);
      btn.className = "diag-choice flex items-center gap-4 w-full text-left px-4 py-3 rounded-xl border-2 border-slate-200 hover:border-brand-400 hover:bg-brand-50 transition-all duration-150 group";
      btn.innerHTML = [
        '<span class="text-2xl">' + o.icon + '</span>',
        '<div>',
        '  <p class="font-semibold text-slate-900 group-hover:text-brand-700">' + o.label + '</p>',
        '  <p class="text-xs text-slate-500">' + o.desc + '</p>',
        '</div>',
        '<svg class="ml-auto w-5 h-5 text-slate-300 group-hover:text-brand-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>',
      ].join("");
      btn.addEventListener("click", function () {
        answers.situation = o.val;
        show("step-3");
        setProgress(50);
      });
      container.appendChild(btn);
    });
  }

  // ── Affichage du résultat ────────────────────────────────────────────────

  function fillResult() {
    var src  = answers.source || "peu_importe";
    var bdgt = answers.budget || "standard";
    var obj  = answers.objectif || "peau";

    var slug = reco[obj] && reco[obj][src] && reco[obj][src][bdgt]
      ? reco[obj][src][bdgt]
      : "nutriandco-collagene-naticol";
    var p = produitsData[slug];
    if (!p) return;

    // Logo
    var logoEl = document.getElementById("result-logo");
    if (logoEl) {
      var initials = p.brand ? p.brand.slice(0, 2).toUpperCase() : "??";
      if (p.image) {
        logoEl.innerHTML = '<img src="' + p.image + '" alt="' + p.brand + '" style="width:100%;height:100%;object-fit:contain;padding:4px;" onerror="this.parentElement.textContent=\'' + initials + '\';" />';
      } else {
        logoEl.textContent = initials;
        logoEl.style.background = "#d44d2e";
        logoEl.style.color = "#fff";
      }
    }

    var brandEl = document.getElementById("result-brand");
    if (brandEl) brandEl.textContent = p.brand || "";

    var titleEl = document.getElementById("result-title");
    if (titleEl) titleEl.textContent = p.title || "";

    var ctaEl = document.getElementById("result-cta");
    if (ctaEl) ctaEl.href = "/produit/" + p.slug;

    var priceEl = document.getElementById("result-price");
    if (priceEl && p.price) {
      priceEl.textContent = p.price.toLocaleString("fr-FR", { style: "currency", currency: "EUR" });
    }

    var starsEl = document.getElementById("result-stars");
    if (starsEl) {
      starsEl.innerHTML = "";
      for (var j = 0; j < 5; j++) {
        var star = document.createElement("span");
        star.textContent = "★";
        star.style.color = j < Math.round(p.rating) ? "#f59e0b" : "#e2e8f0";
        star.style.fontSize = "1.125rem";
        starsEl.appendChild(star);
      }
      var rspan = document.createElement("span");
      rspan.style.cssText = "font-size:0.875rem;font-weight:600;color:#334155;margin-left:4px;";
      rspan.textContent = p.rating + "/5";
      starsEl.appendChild(rspan);
    }

    var whyEl = document.getElementById("result-why");
    if (whyEl) {
      var why = whys[obj] && whys[obj][src] && whys[obj][src][bdgt]
        ? whys[obj][src][bdgt]
        : "";
      whyEl.textContent = why;
    }

    show("step-result");
    setProgress(100);
  }

  // ── Listeners clics choix ────────────────────────────────────────────────

  document.addEventListener("click", function (e) {
    var btn = e.target.closest(".diag-choice");
    if (!btn) return;
    var step = btn.getAttribute("data-step");
    var val  = btn.getAttribute("data-val");
    if (!step || !val) return;

    if (step === "1") {
      answers.objectif = val;
      renderStep2(val);
      show("step-2");
      setProgress(25);
    } else if (step === "3") {
      answers.source = val;
      show("step-4");
      setProgress(75);
    } else if (step === "4") {
      answers.budget = val;
      show("step-email");
      setProgress(90);
    }
  });

  // ── Boutons retour ───────────────────────────────────────────────────────

  function on(id, fn) {
    var el = document.getElementById(id);
    if (el) el.addEventListener("click", fn);
  }

  on("diag-back-1", function () { show("step-1"); setProgress(25); });
  on("diag-back-2", function () { show("step-2"); setProgress(25); });
  on("diag-back-3", function () { show("step-3"); setProgress(50); });
  on("diag-back-4", function () { show("step-4"); setProgress(75); });

  // ── Soumission email ─────────────────────────────────────────────────────

  var emailForm = document.getElementById("diag-email-form");
  if (emailForm) {
    emailForm.addEventListener("submit", function (e) {
      e.preventDefault();

      var inputEl   = document.getElementById("diag-email-input");
      var errorEl   = document.getElementById("diag-email-error");
      var btnText   = document.getElementById("diag-email-btn-text");
      var spinner   = document.getElementById("diag-email-spinner");
      var btn       = document.getElementById("diag-email-btn");

      var email = inputEl ? inputEl.value.trim() : "";
      var emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

      if (!emailRe.test(email)) {
        if (errorEl) errorEl.classList.remove("hidden");
        return;
      }
      if (errorEl) errorEl.classList.add("hidden");

      // UI loading
      if (btnText) btnText.textContent = "Envoi en cours…";
      if (spinner) spinner.classList.remove("hidden");
      if (btn) btn.disabled = true;

      // Slug recommandé
      var src  = answers.source || "peu_importe";
      var bdgt = answers.budget || "standard";
      var obj  = answers.objectif || "peau";
      var slug = reco[obj] && reco[obj][src] && reco[obj][src][bdgt]
        ? reco[obj][src][bdgt]
        : "nutriandco-collagene-naticol";
      var p = produitsData[slug] || {};

      fetch("/api/diagnostic-lead", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          email:        email,
          objectif:     answers.objectif,
          situation:    answers.situation,
          source:       answers.source,
          budget:       answers.budget,
          productSlug:  p.slug || slug,
          productTitle: p.title || "",
          productBrand: p.brand || "",
        }),
      })
      .then(function (res) {
        if (!res.ok) throw new Error("HTTP " + res.status);
        return res.json();
      })
      .then(function () {
        fillResult();
      })
      .catch(function (err) {
        console.error("diagnostic-lead error:", err);
        // On affiche quand même le résultat si l'API échoue
        fillResult();
        if (btnText) btnText.textContent = "Voir ma recommandation →";
        if (spinner) spinner.classList.add("hidden");
        if (btn) btn.disabled = false;
      });
    });
  }

  // ── Restart ──────────────────────────────────────────────────────────────

  on("diag-restart", function () {
    answers = { objectif: "", situation: "", source: "", budget: "" };
    var inputEl = document.getElementById("diag-email-input");
    if (inputEl) inputEl.value = "";
    var btn = document.getElementById("diag-email-btn");
    var btnText = document.getElementById("diag-email-btn-text");
    var spinner = document.getElementById("diag-email-spinner");
    if (btn) btn.disabled = false;
    if (btnText) btnText.textContent = "Voir ma recommandation →";
    if (spinner) spinner.classList.add("hidden");
    show("step-1");
    setProgress(25);
  });

})();
</script>
