const produitsData = produits.reduce<Record<string, {
  title: string; brand: string; price?: number; rating: number; image?: string; slug: string;
}>>((acc, p) => {
  acc[p.id] = {
    title:  p.data.title,
    brand:  p.data.brand,
    price:  p.data.price,
    rating: p.data.rating,
    image:  p.data.image,
    slug:   p.id,
  };
  return acc;
}, {});
---

<section class="bg-gradient-to-br from-brand-600 to-brand-800 py-16 px-4" id="diagnostic">
  <div class="max-w-2xl mx-auto">

    <div class="text-center mb-8">
      <span class="inline-block bg-white/20 text-white text-xs font-semibold px-3 py-1 rounded-full mb-3 uppercase tracking-wide">
        Outil gratuit
      </span>
      <h2 class="text-3xl font-bold text-white mb-3">Quel collagène vous convient ?</h2>
      <p class="text-brand-100">4 questions · Recommandation personnalisée · Protocole par email</p>
    </div>

    <div class="bg-white rounded-2xl shadow-xl overflow-hidden" id="diag-card">

      <!-- Barre de progression -->
      <div class="h-1.5 bg-slate-100">
        <div id="diag-progress" class="h-full bg-brand-500 transition-all duration-500" style="width:25%"></div>
      </div>

      <div id="diag-steps" class="p-8">

        <!-- ── ÉTAPE 1 : Objectif ───────────────────────────────────── -->
        <div id="step-1">
          <p class="text-xs font-semibold text-brand-600 uppercase tracking-wide mb-1">Étape 1 / 4</p>
          <h3 class="text-xl font-bold text-slate-900 mb-6">Quel est votre objectif principal ?</h3>
          <div class="grid grid-cols-1 gap-3">
            {[
              { val: 'peau',          icon: '✨', label: 'Peau & anti-âge',         desc: 'Rides, fermeté, éclat' },
              { val: 'articulations', icon: '🦴', label: 'Articulations & mobilité', desc: 'Douleurs, cartilage, souplesse' },
              { val: 'sport',         icon: '💪', label: 'Sport & récupération',     desc: 'Tendons, performance, récupération' },
              { val: 'cheveux',       icon: '💆', label: 'Cheveux & ongles',         desc: 'Pousse, résistance, brillance' },
              { val: 'vitalite',      icon: '⚡', label: 'Vitalité & énergie',       desc: 'Sommeil, fatigue, bien-être général' },
            ].map(o => (
              <button type="button" data-step="1" data-val={o.val}
                class="diag-choice flex items-center gap-4 w-full text-left px-4 py-3 rounded-xl border-2 border-slate-200 hover:border-brand-400 hover:bg-brand-50 transition-all duration-150 group">
                <span class="text-2xl">{o.icon}</span>
                <div>
                  <p class="font-semibold text-slate-900 group-hover:text-brand-700">{o.label}</p>
                  <p class="text-xs text-slate-500">{o.desc}</p>
                </div>
                <svg class="ml-auto w-5 h-5 text-slate-300 group-hover:text-brand-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            ))}
          </div>
        </div>

        <!-- ── ÉTAPE 2 : Situation (remplie dynamiquement en JS) ──── -->
        <div id="step-2" style="display:none">
          <p class="text-xs font-semibold text-brand-600 uppercase tracking-wide mb-1">Étape 2 / 4</p>
          <h3 class="text-xl font-bold text-slate-900 mb-6" id="step-2-title">Précisez votre situation</h3>
          <div class="grid grid-cols-1 gap-3" id="step-2-options"></div>
          <button id="diag-back-1" type="button" class="mt-5 text-sm text-slate-400 hover:text-slate-700 flex items-center gap-1">← Retour</button>
        </div>

        <!-- ── ÉTAPE 3 : Source ────────────────────────────────────── -->
        <div id="step-3" style="display:none">
          <p class="text-xs font-semibold text-brand-600 uppercase tracking-wide mb-1">Étape 3 / 4</p>
          <h3 class="text-xl font-bold text-slate-900 mb-2">Votre source de collagène</h3>
          <p class="text-sm text-slate-500 mb-6">Régime alimentaire ou préférence personnelle</p>
          <div class="grid grid-cols-1 gap-3">
            {[
              { val: 'marin',       icon: '🐟', label: 'Marin (poisson)',   desc: 'Biodisponibilité maximale — idéal peau & cheveux' },
              { val: 'bovin',       icon: '🐄', label: 'Bovin (bœuf)',      desc: 'Polyvalent, bon rapport qualité/prix, types I & III' },
              { val: 'peu_importe', icon: '🤷', label: 'Peu importe',       desc: 'Je veux le plus efficace selon mon objectif' },
            ].map(o => (
              <button type="button" data-step="3" data-val={o.val}
                class="diag-choice flex items-center gap-4 w-full text-left px-4 py-3 rounded-xl border-2 border-slate-200 hover:border-brand-400 hover:bg-brand-50 transition-all duration-150 group">
                <span class="text-2xl">{o.icon}</span>
                <div>
                  <p class="font-semibold text-slate-900 group-hover:text-brand-700">{o.label}</p>
                  <p class="text-xs text-slate-500">{o.desc}</p>
                </div>
                <svg class="ml-auto w-5 h-5 text-slate-300 group-hover:text-brand-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            ))}
          </div>
          <button id="diag-back-2" type="button" class="mt-5 text-sm text-slate-400 hover:text-slate-700 flex items-center gap-1">← Retour</button>
        </div>

        <!-- ── ÉTAPE 4 : Budget ────────────────────────────────────── -->
        <div id="step-4" style="display:none">
          <p class="text-xs font-semibold text-brand-600 uppercase tracking-wide mb-1">Étape 4 / 4</p>
          <h3 class="text-xl font-bold text-slate-900 mb-6">Quel budget mensuel ?</h3>
          <div class="grid grid-cols-1 gap-3">
            {[
              { val: 'eco',      icon: '💶', label: 'Économique', desc: 'Moins de 25 €/mois' },
              { val: 'standard', icon: '💳', label: 'Standard',   desc: '25 à 45 €/mois' },
              { val: 'premium',  icon: '💎', label: 'Premium',    desc: 'Plus de 45 €/mois' },
            ].map(o => (
              <button type="button" data-step="4" data-val={o.val}
                class="diag-choice flex items-center gap-4 w-full text-left px-4 py-3 rounded-xl border-2 border-slate-200 hover:border-brand-400 hover:bg-brand-50 transition-all duration-150 group">
                <span class="text-2xl">{o.icon}</span>
                <div>
                  <p class="font-semibold text-slate-900 group-hover:text-brand-700">{o.label}</p>
                  <p class="text-xs text-slate-500">{o.desc}</p>
                </div>
                <svg class="ml-auto w-5 h-5 text-slate-300 group-hover:text-brand-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            ))}
          </div>
          <button id="diag-back-3" type="button" class="mt-5 text-sm text-slate-400 hover:text-slate-700 flex items-center gap-1">← Retour</button>
        </div>

        <!-- ── ÉTAPE EMAIL : Déblocage du résultat ─────────────────── -->
        <div id="step-email" style="display:none">
          <div class="text-center mb-6">
            <div class="w-14 h-14 bg-brand-100 rounded-2xl flex items-center justify-center text-2xl mx-auto mb-4">📩</div>
            <h3 class="text-xl font-bold text-slate-900 mb-2">Votre sélection est prête</h3>
            <p class="text-sm text-slate-500">Entrez votre email pour voir votre recommandation et recevoir le protocole complet détaillé.</p>
          </div>

          <form id="diag-email-form" novalidate class="space-y-3">
            <input
              type="email"
              id="diag-email-input"
              placeholder="votre@email.fr"
              autocomplete="email"
              class="w-full px-4 py-3 border-2 border-slate-200 rounded-xl text-sm focus:outline-none focus:border-brand-400 transition-colors"
              required
            />
            <p id="diag-email-error" class="text-xs text-red-500 hidden">Veuillez saisir une adresse email valide.</p>
            <button type="submit" id="diag-email-btn"
              class="w-full bg-brand-600 hover:bg-brand-700 text-white font-semibold py-3.5 rounded-xl text-base transition-colors flex items-center justify-center gap-2">
              <span id="diag-email-btn-text">Voir ma recommandation →</span>
              <svg id="diag-email-spinner" class="hidden w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path>
              </svg>
            </button>
            <p class="text-xs text-slate-400 text-center">Pas de spam · Protocole personnalisé · Désinscription en 1 clic</p>
          </form>

          <button id="diag-back-4" type="button" class="mt-5 text-sm text-slate-400 hover:text-slate-700 flex items-center gap-1">← Retour</button>
        </div>

        <!-- ── RÉSULTAT (affiché après soumission email) ───────────── -->
        <div id="step-result" style="display:none">
          <div class="text-center mb-5">
            <span class="inline-flex items-center gap-2 bg-brand-50 text-brand-700 text-sm font-semibold px-4 py-2 rounded-full border border-brand-200">
              ✅ Recommandation personnalisée
            </span>
          </div>

          <!-- Carte produit -->
          <div class="border-2 border-brand-200 rounded-xl overflow-hidden mb-4">
            <div class="bg-brand-600 text-white text-xs font-bold text-center py-2 uppercase tracking-wide">
              ⭐ Sélection pour votre profil
            </div>
            <div class="p-5">
              <div class="flex items-center gap-4 mb-4">
                <div id="result-logo" class="w-16 h-16 rounded-xl bg-slate-100 flex items-center justify-center flex-shrink-0 overflow-hidden text-sm font-bold text-slate-500"></div>
                <div>
                  <p id="result-brand" class="text-xs text-slate-500 mb-0.5"></p>
                  <h4 id="result-title" class="font-bold text-slate-900 text-base leading-snug"></h4>
                </div>
              </div>
              <div id="result-stars" class="flex items-center gap-1 mb-2"></div>
              <p id="result-price" class="text-2xl font-bold text-slate-900 mb-1"></p>
              <p id="result-why" class="text-sm text-slate-600 mb-5 leading-relaxed"></p>
              <a id="result-cta" href="#"
                class="block w-full text-center bg-brand-600 hover:bg-brand-700 text-white font-semibold py-3 rounded-xl transition-colors text-base">
                Voir la fiche complète →
              </a>
            </div>
          </div>

          <!-- Confirmation email -->
          <div class="bg-slate-50 border border-slate-200 rounded-xl px-5 py-4 flex items-start gap-3 mb-4">
            <span class="text-xl mt-0.5 flex-shrink-0">📬</span>
            <p class="text-sm text-slate-600 leading-relaxed">
              <strong class="text-slate-900">Protocole envoyé !</strong><br/>
              Dosages, durée, études scientifiques et conseils pratiques dans votre boîte mail. Vérifiez les spams si besoin.
            </p>
          </div>

          <button id="diag-restart" type="button" class="w-full text-sm text-slate-400 hover:text-slate-700 text-center py-2">
            ↺ Recommencer le diagnostic
          </button>
        </div>

      </div>
    </div>
  </div>
</section>

