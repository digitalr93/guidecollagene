---
/**
 * DiagnosticWidget.astro
 * 4 questions + email gating → recommandation personnalisée
 * Flux : objectif → situation → source → budget → email → résultat
 */
import { getCollection } from 'astro:content';

const produits = await getCollection('produits', p => !p.data.draft);

// Matrice [objectif][source][budget] → slug produit
const reco: Record<string, Record<string, Record<string, string>>> = {
