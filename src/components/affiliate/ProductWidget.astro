---
import AffiliateButton from './AffiliateButton.astro';

interface Product {
  id: string;
  data: {
    title: string;
    brand: string;
    rating: number;
    reviewCount: number;
    price?: number;
    currency: string;
    image?: string;
    merchant: string;
    affiliateUrl: string;
    category: string;
  };
}

interface Props {
  products: Product[];
  title?: string;
}

const { products, title = '⭐ Nos meilleures sélections' } = Astro.props;

function stars(r: number) {
  return '★'.repeat(Math.round(r)) + '☆'.repeat(5 - Math.round(r));
}

// Brand initials for placeholder
function initials(brand: string) {
  return brand.split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase();
}

const brandColors: Record<string, string> = {
  nutripure: 'bg-emerald-600', nutriandco: 'bg-blue-600',
  dynveo: 'bg-purple-600', novoma: 'bg-teal-600',
  'vital proteins': 'bg-rose-600', 'd-lab': 'bg-fuchsia-700',
  valebio: 'bg-green-700', 'twenty dc': 'bg-cyan-600',
  granions: 'bg-orange-600', 'sunday natural': 'bg-amber-700',
  bulk: 'bg-gray-700', myprotein: 'bg-red-600',
  'ancient nutrition': 'bg-stone-600', biocyte: 'bg-indigo-600',
  'les miraculeux': 'bg-pink-500', 'ana maria lajusticia': 'bg-yellow-700',
};

function brandColor(brand: string) {
  const key = brand.toLowerCase();
  for (const [k, v] of Object.entries(brandColors)) {
    if (key.includes(k)) return v;
  }
  return 'bg-slate-600';
}
---

<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
  <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-4 py-3">
    <p class="text-white font-semibold text-sm">{title}</p>
  </div>

  <div class="divide-y divide-slate-100">
    {products.map((p, i) => (
      <div class="p-4">
        {/* Rang */}
        {i === 0 && (
          <span class="inline-flex items-center gap-1 text-xs font-semibold text-amber-700 bg-amber-50 border border-amber-200 rounded-full px-2 py-0.5 mb-3">
            Meilleur choix
          </span>
        )}

        <div class="flex gap-3 items-start">
          {/* Image ou placeholder */}
          <div class="flex-shrink-0">
            {p.data.image ? (
              <img
                src={p.data.image}
                alt={p.data.title}
                class="w-16 h-16 object-contain rounded-lg bg-slate-50"
                loading="lazy"
              />
            ) : (
              <div class:list={['w-16 h-16 rounded-lg flex items-center justify-center text-white font-bold text-lg', brandColor(p.data.brand)]}>
                {initials(p.data.brand)}
              </div>
            )}
          </div>

          <div class="flex-1 min-w-0">
            <a href={`/produit/${p.id}`} class="font-semibold text-slate-900 text-sm hover:text-blue-600 transition-colors line-clamp-2 leading-snug">
              {p.data.title}
            </a>
            <p class="text-xs text-slate-400 mt-0.5">{p.data.brand}</p>

            <div class="flex items-center gap-1 mt-1">
              <span class="text-amber-400 text-xs">{stars(p.data.rating)}</span>
              <span class="text-xs font-medium text-slate-700">{p.data.rating}/5</span>
            </div>

            {p.data.price && (
              <p class="text-sm font-bold text-slate-900 mt-1">
                {p.data.price.toLocaleString('fr-FR', { style: 'currency', currency: p.data.currency })}
              </p>
            )}
          </div>
        </div>

        <div class="mt-3">
          <AffiliateButton
            productId={p.id}
            productSlug={`/produit/${p.id}`}
            merchant={p.data.merchant}
            affiliateUrl={p.data.affiliateUrl}
            sourcePage="sidebar-widget"
            position={i + 1}
            label="Voir le prix →"
            class="w-full text-sm py-2 justify-center"
          />
        </div>
      </div>
    ))}
  </div>

  <div class="px-4 pb-3 text-center">
    <a href="/comparatif" class="text-xs text-blue-600 hover:underline">
      Voir tous les produits →
    </a>
  </div>

  <p class="text-center text-xs text-slate-400 pb-3 px-4">
    * Liens affiliés — sans surcoût pour vous
  </p>
</div>
