---
import BaseLayout from './BaseLayout.astro';
import ProductWidget from '../components/affiliate/ProductWidget.astro';
import RelatedArticles from '../components/article/RelatedArticles.astro';
import { getCollection } from 'astro:content';
import { SITE_URL } from '../lib/seo';

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  author: string;
  category: string;
  image?: string;
  imageAlt?: string;
  faq?: { question: string; answer: string }[];
  slug?: string;
  featuredProducts?: string[];
  keyPoints?: string[];
}

const {
  title,
  description,
  publishedAt,
  updatedAt,
  author,
  category,
  image,
  imageAlt,
  faq,
  slug,
  featuredProducts: featuredProductIds,
  keyPoints,
} = Astro.props;

// "En résumé" : keyPoints transmis depuis [slug].astro (H2 auto ou keyPoints frontmatter)
const summaryPoints: string[] = keyPoints ?? [];

const canonical = `${SITE_URL}${Astro.url.pathname}`;

// Sidebar: top 3 produits par note (pas de filtre featured)
const allProducts = await getCollection('produits', (p) => !p.data.draft);
const sidebarProducts = allProducts
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.rating - a.data.rating;
  })
  .slice(0, 3);

// Sidebar: related articles (same category, exclude current)
const allArticles = await getCollection('articles', (a) => !a.data.draft);
const relatedArticles = allArticles
  .filter((a) => a.id !== slug && a.data.category === category)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 5);

// Fallback: if not enough same-category articles, fill with recent articles
const fallbackArticles = allArticles
  .filter((a) => a.id !== slug && a.data.category !== category)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const sidebarArticles = relatedArticles.length >= 3
  ? relatedArticles
  : [...relatedArticles, ...fallbackArticles].slice(0, 5);

// Featured products (guides d'achat) — logos inline dans l'article, featured en premier
const inlineProducts = featuredProductIds?.length
  ? allProducts
      .filter((p) => featuredProductIds.includes(p.id))
      .sort((a, b) => {
        if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
        return b.data.rating - a.data.rating;
      })
  : [];

// JSON-LD Article
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: publishedAt.toISOString(),
  dateModified: (updatedAt ?? publishedAt).toISOString(),
  author: {
    '@type': 'Person',
    name: author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Guide Collagène',
    url: SITE_URL,
  },
  ...(image && { image: `${SITE_URL}${image}` }),
};

const faqSchema = faq?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faq.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: { '@type': 'Answer', text: item.answer },
      })),
    }
  : null;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Guides', item: `${SITE_URL}/guide` },
    { '@type': 'ListItem', position: 3, name: title, item: canonical },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogType="article"
  ogImage={image}
  publishedAt={publishedAt}
  updatedAt={updatedAt}
  author={author}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="max-w-6xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="text-sm text-slate-500 mb-8" aria-label="Fil d'Ariane">
      <ol class="flex items-center gap-2 flex-wrap">
        <li><a href="/" class="hover:text-slate-800">Accueil</a></li>
        <li aria-hidden="true">›</li>
        <li><a href="/guide" class="hover:text-slate-800">Guides</a></li>
        <li aria-hidden="true">›</li>
        <li class="text-slate-800 line-clamp-1" aria-current="page">{title}</li>
      </ol>
    </nav>

    <!-- 2-col grid: article + sticky sidebar -->
    <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_320px] lg:gap-12">

      <!-- Main article -->
      <article>
        <header class="mb-10">
          <div class="mb-3">
            <span class="badge bg-brand-100 text-brand-800">{category}</span>
          </div>
          <h1 class="text-4xl font-bold text-slate-900 mb-4 leading-tight">{title}</h1>
          <p class="text-xl text-slate-600 mb-6">{description}</p>
          <div class="flex items-center gap-4 text-sm text-slate-500 flex-wrap">
            <span>Par <strong class="text-slate-700">{author}</strong></span>
            <span>·</span>
            <time datetime={publishedAt.toISOString()}>
              {publishedAt.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            {updatedAt && (
              <>
                <span>·</span>
                <span>Mis à jour le <time datetime={updatedAt.toISOString()}>
                  {updatedAt.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time></span>
              </>
            )}
          </div>
        </header>

        {image && (
          <figure class="mb-10">
            <img src={image} alt={imageAlt ?? title} class="w-full rounded-xl object-cover" loading="eager" />
          </figure>
        )}

        <!-- ═══ EN RÉSUMÉ ═══════════════════════════════════════════════ -->
        {summaryPoints.length > 0 && (
          <div class="not-prose mb-10 rounded-2xl border border-brand-200 bg-brand-50 overflow-hidden">
            <div class="flex items-center gap-2 px-5 py-3 bg-brand-600">
              <svg class="w-4 h-4 text-white flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
              </svg>
              <span class="text-white font-semibold text-sm">En résumé</span>
            </div>
            <ul class="px-5 py-4 space-y-2.5">
              {summaryPoints.map((point) => (
                <li class="flex items-start gap-2.5 text-sm text-slate-700 leading-relaxed">
                  <svg class="w-4 h-4 text-brand-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  <span>{point}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Bloc logos produits (guides d'achat uniquement) -->
        {inlineProducts.length > 0 && (
          <div class="not-prose mb-10 rounded-xl border border-slate-200 bg-slate-50 overflow-hidden">
            <div class="px-5 py-3 bg-brand-600 flex items-center gap-2">
              <span class="text-white font-semibold text-sm">🏆 Nos sélections dans ce guide</span>
              <span class="ml-auto text-brand-200 text-xs">{inlineProducts.length} produit{inlineProducts.length > 1 ? 's' : ''}</span>
            </div>
            <div class="divide-y divide-slate-200">
              {inlineProducts.map((p, i) => (
                <div class="flex items-center gap-4 px-5 py-4">
                  {/* Rang */}
                  <span class="flex-shrink-0 w-7 h-7 rounded-full bg-brand-100 text-brand-700 font-bold text-xs flex items-center justify-center">
                    {i + 1}
                  </span>
                  {/* Logo marque */}
                  <div class="flex-shrink-0">
                    {p.data.image ? (
                      <>
                        <img
                          src={p.data.image}
                          alt={`Logo ${p.data.brand}`}
                          class="w-12 h-12 object-contain rounded-lg bg-white border border-slate-100 p-1"
                          loading="lazy"
                          width="48"
                          height="48"
                          onerror="this.style.display='none';this.nextElementSibling.removeAttribute('hidden');"
                        />
                        <div hidden class="w-12 h-12 rounded-lg bg-brand-600 flex items-center justify-center text-white font-bold text-sm">
                          {p.data.brand.slice(0, 2).toUpperCase()}
                        </div>
                      </>
                    ) : (
                      <div class="w-12 h-12 rounded-lg bg-brand-600 flex items-center justify-center text-white font-bold text-sm">
                        {p.data.brand.slice(0, 2).toUpperCase()}
                      </div>
                    )}
                  </div>
                  {/* Infos */}
                  <div class="flex-1 min-w-0">
                    <a href={`/produit/${p.id}`} class="font-semibold text-slate-900 hover:text-brand-600 transition-colors text-sm leading-snug line-clamp-2">
                      {p.data.title}
                    </a>
                    <div class="flex items-center gap-2 mt-0.5">
                      <span class="text-xs text-slate-500">{p.data.brand}</span>
                      <span class="text-amber-400 text-xs">{'★'.repeat(Math.round(p.data.rating))}</span>
                      <span class="text-xs font-medium text-slate-700">{p.data.rating}/5</span>
                    </div>
                  </div>
                  {/* Prix + CTA */}
                  <div class="flex-shrink-0 text-right">
                    {p.data.price && (
                      <p class="text-sm font-bold text-slate-900 mb-1">
                        {p.data.price.toLocaleString('fr-FR', { style: 'currency', currency: 'EUR' })}
                      </p>
                    )}
                    <a
                      href={`/produit/${p.id}`}
                      class="inline-flex items-center text-xs font-semibold text-brand-600 hover:text-brand-800 transition-colors"
                    >
                      Voir →
                    </a>
                  </div>
                </div>
              ))}
            </div>
            <p class="text-center text-xs text-slate-400 py-2 border-t border-slate-200">
              * Liens affiliés — sans surcoût pour vous
            </p>
          </div>
        )}

        <!-- Mobile sidebar (shown before prose on small screens) -->
        {sidebarProducts.length > 0 && (
          <div class="lg:hidden mb-8">
            <ProductWidget products={sidebarProducts} />
          </div>
        )}

        <div class="prose max-w-none">
          <slot />
        </div>

        <!-- ═══ VERDICT TEMPLATE (déplacé après le 3e H2 par JS) ═══════ -->
        {inlineProducts.length > 0 && (() => {
          const top = inlineProducts[0];
          return (
            <div id="verdict-box" class="hidden not-prose my-8 rounded-2xl border-2 border-brand-300 bg-white overflow-hidden shadow-sm">
              <div class="px-5 py-3 bg-gradient-to-r from-brand-600 to-brand-700 flex items-center gap-2">
                <span class="text-lg">🏆</span>
                <span class="text-white font-bold text-sm uppercase tracking-wide">Notre verdict — meilleur choix</span>
              </div>
              <div class="p-5 flex items-center gap-4">
                {top.data.image ? (
                  <img src={top.data.image} alt={top.data.brand} width="72" height="72"
                    class="w-18 h-18 object-contain rounded-xl bg-slate-50 border border-slate-100 p-1 flex-shrink-0"
                    loading="lazy" style="width:72px;height:72px;" />
                ) : (
                  <div class="w-16 h-16 rounded-xl bg-brand-600 flex items-center justify-center text-white font-bold text-xl flex-shrink-0">
                    {top.data.brand.slice(0, 2).toUpperCase()}
                  </div>
                )}
                <div class="flex-1 min-w-0">
                  <p class="text-xs text-slate-500 mb-0.5">{top.data.brand}</p>
                  <p class="font-bold text-slate-900 leading-snug mb-1">{top.data.title}</p>
                  <div class="flex items-center gap-1 mb-2">
                    {Array.from({ length: 5 }).map((_, j) => (
                      <svg class:list={['w-4 h-4', j < Math.round(top.data.rating) ? 'text-amber-400' : 'text-slate-200']}
                        fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                      </svg>
                    ))}
                    <span class="text-sm font-semibold text-slate-700 ml-1">{top.data.rating}/5</span>
                  </div>
                  <a href={`/produit/${top.id}`}
                    class="inline-flex items-center gap-2 bg-brand-600 hover:bg-brand-700 text-white text-sm font-semibold px-4 py-2 rounded-xl transition-colors">
                    Voir l'avis complet →
                  </a>
                </div>
              </div>
              <p class="text-center text-xs text-slate-400 pb-3">* Lien affilié — sans surcoût pour vous</p>
            </div>
          );
        })()}

        {faq?.length && (
          <section class="mt-16 border-t border-slate-200 pt-10">
            <h2 class="text-2xl font-bold text-slate-900 mb-6">Questions fréquentes</h2>
            <div class="space-y-2" id="article-faq">
              {faq.map((item, i) => (
                <div class="border border-slate-200 rounded-xl overflow-hidden">
                  <button
                    type="button"
                    class="faq-btn w-full flex items-center justify-between px-5 py-4 text-left font-semibold text-slate-900 hover:bg-slate-50 transition-colors gap-4"
                    aria-expanded={i === 0 ? 'true' : 'false'}
                  >
                    <span>{item.question}</span>
                    <svg class="faq-chevron flex-shrink-0 w-5 h-5 text-brand-500 transition-transform duration-200" style={i === 0 ? 'transform:rotate(180deg)' : ''} viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M5 8l5 5 5-5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                  <div class="faq-panel px-5 pb-4 text-slate-600 leading-relaxed" style={i === 0 ? '' : 'display:none'}>
                    {item.answer}
                  </div>
                </div>
              ))}
            </div>
          </section>
        )}
      </article>

      <!-- Sticky sidebar (desktop only) -->
      <aside class="hidden lg:block" style="align-self: stretch;">
        <div class="sticky top-24 space-y-6">
          {sidebarProducts.length > 0 && (
            <ProductWidget products={sidebarProducts} />
          )}
          {sidebarArticles.length > 0 && (
            <RelatedArticles articles={sidebarArticles} />
          )}
        </div>
      </aside>

    </div>
  </div>
<!-- ═══ STICKY COUPON BAR — Nutrimuscle ══════════════════════════ -->
<div id="sticky-cta"
  class="hidden fixed bottom-0 left-0 right-0 z-50 shadow-2xl"
  role="complementary" aria-label="Code promo Nutrimuscle">
  <!-- Fil décoratif couleur -->
  <div class="h-1 bg-gradient-to-r from-amber-400 via-amber-300 to-amber-400"></div>
  <div class="bg-slate-900 px-4 py-3">
    <div class="max-w-6xl mx-auto flex items-center gap-3 sm:gap-5">

      <!-- Icône + marque -->
      <div class="flex items-center gap-2 flex-shrink-0">
        <span class="text-xl" aria-hidden="true">🏷️</span>
        <div class="hidden sm:block leading-tight">
          <p class="text-amber-400 text-xs font-bold uppercase tracking-wide">Nutrimuscle</p>
          <p class="text-slate-400 text-xs">−5% cumulables</p>
        </div>
      </div>

      <!-- Code promo avec bouton copier -->
      <div class="flex items-center gap-3 flex-1 min-w-0">
        <div class="flex items-center gap-2 bg-slate-800 border border-dashed border-amber-500/60 rounded-lg px-3 py-1.5 flex-shrink-0">
          <span class="text-amber-400 font-mono font-bold text-sm tracking-widest select-all">NME_GC</span>
          <button id="copy-code"
            class="text-slate-500 hover:text-amber-400 transition-colors"
            aria-label="Copier le code promo">
            <svg id="copy-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
            </svg>
            <svg id="check-icon" class="w-4 h-4 hidden text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          </button>
        </div>
        <p class="text-slate-400 text-xs hidden sm:block truncate">
          cumulables avec les offres en cours
        </p>
      </div>

      <!-- CTA + fermer -->
      <div class="flex items-center gap-2 flex-shrink-0">
        <a href="https://nmsquad.link/02ocm"
          target="_blank"
          rel="nofollow noopener sponsored"
          class="bg-amber-500 hover:bg-amber-400 text-slate-900 text-sm font-bold px-4 py-2 rounded-xl transition-colors whitespace-nowrap">
          En profiter →
        </a>
        <button id="sticky-close"
          class="text-slate-500 hover:text-white p-1 transition-colors"
          aria-label="Fermer">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

    </div>
  </div>
</div>

<script>
  // ── FAQ accordion ─────────────────────────────────────────────────────
  document.querySelectorAll('#article-faq .faq-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const panel = btn.nextElementSibling as HTMLElement;
      const chevron = btn.querySelector('.faq-chevron') as HTMLElement;
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      document.querySelectorAll('#article-faq .faq-btn').forEach((b) => {
        const p = b.nextElementSibling as HTMLElement;
        const c = b.querySelector('.faq-chevron') as HTMLElement;
        b.setAttribute('aria-expanded', 'false');
        if (p) p.style.display = 'none';
        if (c) c.style.transform = '';
      });

      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true');
        if (panel) panel.style.display = '';
        if (chevron) chevron.style.transform = 'rotate(180deg)';
      }
    });
  });

  // ── Verdict box : injecter après le 3e H2 de l'article ───────────────
  const verdictBox = document.getElementById('verdict-box');
  if (verdictBox) {
    const headings = document.querySelectorAll('article .prose h2');
    const target = headings[2] ?? headings[headings.length - 1];
    if (target) {
      verdictBox.classList.remove('hidden');
      target.insertAdjacentElement('afterend', verdictBox);
    }
  }

  // ── Sticky coupon bar ─────────────────────────────────────────────────
  const cta = document.getElementById('sticky-cta') as HTMLElement | null;
  const closeBtn = document.getElementById('sticky-close');
  const copyBtn = document.getElementById('copy-code');
  const copyIcon = document.getElementById('copy-icon');
  const checkIcon = document.getElementById('check-icon');
  let dismissed = false;

  closeBtn?.addEventListener('click', () => {
    dismissed = true;
    cta?.classList.add('hidden');
  });

  // Helper : envoie un événement au tracking /api/click via sendBeacon
  const trackCoupon = (action: string) => {
    const payload = JSON.stringify({
      clickId: `nm-${action}-${Date.now()}`,
      productId: 'nutrimuscle-coupon',
      merchant: 'nutrimuscle',
      destinationUrl: action === 'copy' ? 'code-copy-NME_GC' : 'https://nmsquad.link/02ocm',
      sourcePage: window.location.pathname,
      device: /Mobi|Android/i.test(navigator.userAgent) ? 'mobile' : 'desktop',
    });
    navigator.sendBeacon('/api/click', new Blob([payload], { type: 'application/json' }));
  };

  copyBtn?.addEventListener('click', () => {
    navigator.clipboard.writeText('NME_GC').then(() => {
      copyIcon?.classList.add('hidden');
      checkIcon?.classList.remove('hidden');
      setTimeout(() => {
        copyIcon?.classList.remove('hidden');
        checkIcon?.classList.add('hidden');
      }, 2000);
      trackCoupon('copy');
    });
  });

  // Track les clics sur "En profiter →"
  document.querySelector('#sticky-cta a[href*="nmsquad"]')
    ?.addEventListener('click', () => trackCoupon('cta'));

  const showCta = () => {
    if (dismissed || !cta) return;
    const scrolled = window.scrollY / Math.max(1, document.body.scrollHeight - window.innerHeight);
    if (scrolled > 0.30) {
      cta.classList.remove('hidden');
    } else {
      cta.classList.add('hidden');
    }
  };

  window.addEventListener('scroll', showCta, { passive: true });
</script>
</BaseLayout>
