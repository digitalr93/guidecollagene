---
import BaseLayout from './BaseLayout.astro';
import ProductWidget from '../components/affiliate/ProductWidget.astro';
import RelatedArticles from '../components/article/RelatedArticles.astro';
import { getCollection } from 'astro:content';
import { SITE_URL } from '../lib/seo';

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  author: string;
  category: string;
  image?: string;
  imageAlt?: string;
  faq?: { question: string; answer: string }[];
  slug?: string;
  featuredProducts?: string[];
}

const {
  title,
  description,
  publishedAt,
  updatedAt,
  author,
  category,
  image,
  imageAlt,
  faq,
  slug,
  featuredProducts: featuredProductIds,
} = Astro.props;

const canonical = `${SITE_URL}${Astro.url.pathname}`;

// Sidebar: top 3 featured products
const allProducts = await getCollection('produits', (p) => !p.data.draft);
const sidebarProducts = allProducts
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.rating - a.data.rating)
  .slice(0, 3);

// Sidebar: related articles (same category, exclude current)
const allArticles = await getCollection('articles', (a) => !a.data.draft);
const relatedArticles = allArticles
  .filter((a) => a.id !== slug && a.data.category === category)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 5);

// Fallback: if not enough same-category articles, fill with recent articles
const fallbackArticles = allArticles
  .filter((a) => a.id !== slug && a.data.category !== category)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const sidebarArticles = relatedArticles.length >= 3
  ? relatedArticles
  : [...relatedArticles, ...fallbackArticles].slice(0, 5);

// Featured products (guides d'achat) — logos inline dans l'article
const inlineProducts = featuredProductIds?.length
  ? allProducts.filter((p) => featuredProductIds.includes(p.id))
  : [];

// JSON-LD Article
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: publishedAt.toISOString(),
  dateModified: (updatedAt ?? publishedAt).toISOString(),
  author: {
    '@type': 'Person',
    name: author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Guide Collagène',
    url: SITE_URL,
  },
  ...(image && { image: `${SITE_URL}${image}` }),
};

const faqSchema = faq?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faq.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: { '@type': 'Answer', text: item.answer },
      })),
    }
  : null;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Guides', item: `${SITE_URL}/guide` },
    { '@type': 'ListItem', position: 3, name: title, item: canonical },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogType="article"
  ogImage={image}
  publishedAt={publishedAt}
  updatedAt={updatedAt}
  author={author}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="max-w-6xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="text-sm text-slate-500 mb-8" aria-label="Fil d'Ariane">
      <ol class="flex items-center gap-2 flex-wrap">
        <li><a href="/" class="hover:text-slate-800">Accueil</a></li>
        <li aria-hidden="true">›</li>
        <li><a href="/guide" class="hover:text-slate-800">Guides</a></li>
        <li aria-hidden="true">›</li>
        <li class="text-slate-800 line-clamp-1" aria-current="page">{title}</li>
      </ol>
    </nav>

    <!-- 2-col grid: article + sticky sidebar -->
    <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_320px] lg:gap-12">

      <!-- Main article -->
      <article>
        <header class="mb-10">
          <div class="mb-3">
            <span class="badge bg-brand-100 text-brand-800">{category}</span>
          </div>
          <h1 class="text-4xl font-bold text-slate-900 mb-4 leading-tight">{title}</h1>
          <p class="text-xl text-slate-600 mb-6">{description}</p>
          <div class="flex items-center gap-4 text-sm text-slate-500 flex-wrap">
            <span>Par <strong class="text-slate-700">{author}</strong></span>
            <span>·</span>
            <time datetime={publishedAt.toISOString()}>
              {publishedAt.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            {updatedAt && (
              <>
                <span>·</span>
                <span>Mis à jour le <time datetime={updatedAt.toISOString()}>
                  {updatedAt.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time></span>
              </>
            )}
          </div>
        </header>

        {image && (
          <figure class="mb-10">
            <img src={image} alt={imageAlt ?? title} class="w-full rounded-xl object-cover" loading="eager" />
          </figure>
        )}

        <!-- Bloc logos produits (guides d'achat uniquement) -->
        {inlineProducts.length > 0 && (
          <div class="not-prose mb-10 rounded-xl border border-slate-200 bg-slate-50 overflow-hidden">
            <div class="px-5 py-3 bg-brand-600 flex items-center gap-2">
              <span class="text-white font-semibold text-sm">🏆 Nos sélections dans ce guide</span>
              <span class="ml-auto text-brand-200 text-xs">{inlineProducts.length} produit{inlineProducts.length > 1 ? 's' : ''}</span>
            </div>
            <div class="divide-y divide-slate-200">
              {inlineProducts.map((p, i) => (
                <div class="flex items-center gap-4 px-5 py-4">
                  {/* Rang */}
                  <span class="flex-shrink-0 w-7 h-7 rounded-full bg-brand-100 text-brand-700 font-bold text-xs flex items-center justify-center">
                    {i + 1}
                  </span>
                  {/* Logo marque */}
                  <div class="flex-shrink-0">
                    {p.data.image ? (
                      <>
                        <img
                          src={p.data.image}
                          alt={`Logo ${p.data.brand}`}
                          class="w-12 h-12 object-contain rounded-lg bg-white border border-slate-100 p-1"
                          loading="lazy"
                          width="48"
                          height="48"
                          onerror="this.style.display='none';this.nextElementSibling.removeAttribute('hidden');"
                        />
                        <div hidden class="w-12 h-12 rounded-lg bg-brand-600 flex items-center justify-center text-white font-bold text-sm">
                          {p.data.brand.slice(0, 2).toUpperCase()}
                        </div>
                      </>
                    ) : (
                      <div class="w-12 h-12 rounded-lg bg-brand-600 flex items-center justify-center text-white font-bold text-sm">
                        {p.data.brand.slice(0, 2).toUpperCase()}
                      </div>
                    )}
                  </div>
                  {/* Infos */}
                  <div class="flex-1 min-w-0">
                    <a href={`/produit/${p.id}`} class="font-semibold text-slate-900 hover:text-brand-600 transition-colors text-sm leading-snug line-clamp-2">
                      {p.data.title}
                    </a>
                    <div class="flex items-center gap-2 mt-0.5">
                      <span class="text-xs text-slate-500">{p.data.brand}</span>
                      <span class="text-amber-400 text-xs">{'★'.repeat(Math.round(p.data.rating))}</span>
                      <span class="text-xs font-medium text-slate-700">{p.data.rating}/5</span>
                    </div>
                  </div>
                  {/* Prix + CTA */}
                  <div class="flex-shrink-0 text-right">
                    {p.data.price && (
                      <p class="text-sm font-bold text-slate-900 mb-1">
                        {p.data.price.toLocaleString('fr-FR', { style: 'currency', currency: 'EUR' })}
                      </p>
                    )}
                    <a
                      href={`/produit/${p.id}`}
                      class="inline-flex items-center text-xs font-semibold text-brand-600 hover:text-brand-800 transition-colors"
                    >
                      Voir →
                    </a>
                  </div>
                </div>
              ))}
            </div>
            <p class="text-center text-xs text-slate-400 py-2 border-t border-slate-200">
              * Liens affiliés — sans surcoût pour vous
            </p>
          </div>
        )}

        <!-- Mobile sidebar (shown before prose on small screens) -->
        {sidebarProducts.length > 0 && (
          <div class="lg:hidden mb-8">
            <ProductWidget products={sidebarProducts} />
          </div>
        )}

        <div class="prose max-w-none">
          <slot />
        </div>

        {faq?.length && (
          <section class="mt-16 border-t border-slate-200 pt-10">
            <h2 class="text-2xl font-bold text-slate-900 mb-6">Questions fréquentes</h2>
            <dl class="space-y-6">
              {faq.map((item) => (
                <div>
                  <dt class="font-semibold text-slate-900 mb-2">{item.question}</dt>
                  <dd class="text-slate-600">{item.answer}</dd>
                </div>
              ))}
            </dl>
          </section>
        )}
      </article>

      <!-- Sticky sidebar (desktop only) -->
      <aside class="hidden lg:block" style="align-self: stretch;">
        <div class="sticky top-24 space-y-6">
          {sidebarProducts.length > 0 && (
            <ProductWidget products={sidebarProducts} />
          )}
          {sidebarArticles.length > 0 && (
            <RelatedArticles articles={sidebarArticles} />
          )}
        </div>
      </aside>

    </div>
  </div>
</BaseLayout>
