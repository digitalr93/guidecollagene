---
import BaseLayout from './BaseLayout.astro';
import { SITE_URL } from '../lib/seo';
import AffiliateButton from '../components/affiliate/AffiliateButton.astro';

interface Props {
  title: string;
  description: string;
  brand: string;
  category: string;
  image?: string;
  imageAlt?: string;
  rating: number;
  reviewCount: number;
  price?: number;
  currency?: string;
  merchant: string;
  affiliateUrl: string;
  productId: string;
  pros: string[];
  cons: string[];
  publishedAt: Date;
  updatedAt?: Date;
  promoCode?: string;
  promoDiscount?: number;
  featured?: boolean;
}

const props = Astro.props;
const {
  title, description, brand, category, image, imageAlt,
  rating, reviewCount, price, currency = 'EUR',
  merchant, affiliateUrl, productId,
  pros, cons, publishedAt, updatedAt,
  promoCode, promoDiscount, featured,
} = props;

const discountedPrice = (price && promoDiscount) ? price * (1 - promoDiscount / 100) : null;

const canonical = `${SITE_URL}${Astro.url.pathname}`;

// JSON-LD Product
const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: title,
  description,
  brand: { '@type': 'Brand', name: brand },
  ...(image && { image: `${SITE_URL}${image}` }),
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: rating,
    reviewCount,
    bestRating: 5,
    worstRating: 1,
  },
  ...(price && {
    offers: {
      '@type': 'Offer',
      price,
      priceCurrency: currency,
      availability: 'https://schema.org/InStock',
      url: canonical,
    },
  }),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Produits', item: `${SITE_URL}/produit` },
    { '@type': 'ListItem', position: 3, name: title, item: canonical },
  ],
};

function renderStars(value: number) {
  return '★'.repeat(Math.round(value)) + '☆'.repeat(5 - Math.round(value));
}
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogType="product"
  ogImage={image}
  publishedAt={publishedAt}
  updatedAt={updatedAt}
>
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="max-w-4xl mx-auto px-4 py-12">
    <!-- Breadcrumb -->
    <nav class="text-sm text-slate-500 mb-6" aria-label="Fil d'Ariane">
      <ol class="flex items-center gap-2 flex-wrap">
        <li><a href="/" class="hover:text-slate-800">Accueil</a></li>
        <li aria-hidden="true">›</li>
        <li><a href="/produit" class="hover:text-slate-800">Produits</a></li>
        <li aria-hidden="true">›</li>
        <li class="text-slate-800" aria-current="page">{title}</li>
      </ol>
    </nav>

    <!-- Hero produit -->
    <div class="grid md:grid-cols-2 gap-10 mb-12">
      <div class="rounded-xl overflow-hidden bg-slate-50 flex items-center justify-center p-8 aspect-square">
        {image ? (
          <>
            <img
              src={image}
              alt={imageAlt ?? title}
              class="w-full h-full object-contain"
              loading="eager"
              onerror="this.style.display='none';this.nextElementSibling.removeAttribute('hidden');"
            />
            <div hidden class="text-6xl font-bold text-brand-200 select-none">
              {brand.slice(0,2).toUpperCase()}
            </div>
          </>
        ) : (
          <div class="text-6xl font-bold text-brand-200 select-none">
            {brand.slice(0,2).toUpperCase()}
          </div>
        )}
      </div>
      <div class="flex flex-col justify-center">
        <div class="flex items-center gap-2 mb-3 flex-wrap">
          <span class="badge bg-emerald-100 text-emerald-800">{category}</span>
          {featured && (
            <span class="inline-flex items-center gap-1 bg-amber-500 text-white text-xs font-bold px-2.5 py-1 rounded-full shadow-sm">
              🥇 Choix n°1
            </span>
          )}
        </div>
        <h1 class="text-3xl font-bold text-slate-900 mb-2">{title}</h1>
        <p class="text-slate-500 mb-3">par {brand}</p>

        <!-- Rating -->
        <div class="flex items-center gap-2 mb-4">
          <span class="text-amber-400 text-lg" aria-hidden="true">{renderStars(rating)}</span>
          <span class="font-semibold">{rating}/5</span>
          <span class="text-slate-500 text-sm">({reviewCount} avis)</span>
        </div>

        <!-- Prix avec compare-at-price si code promo -->
        {price && (
          <div class="mb-4">
            {discountedPrice ? (
              <>
                <div class="flex items-baseline gap-3">
                  <p class="text-3xl font-bold text-emerald-600">
                    {discountedPrice.toLocaleString('fr-FR', { style: 'currency', currency, maximumFractionDigits: 2 })}
                  </p>
                  <p class="text-lg text-slate-400 line-through">
                    {price.toLocaleString('fr-FR', { style: 'currency', currency })}
                  </p>
                </div>
                <div class="inline-flex items-center gap-1.5 mt-1.5 bg-amber-50 border border-amber-200 rounded-lg px-3 py-1.5">
                  <span class="text-sm">🏷️</span>
                  <span class="text-amber-700 text-sm font-semibold">Code <strong class="font-mono tracking-wider">{promoCode}</strong> — -{promoDiscount}% cumulables</span>
                </div>
              </>
            ) : (
              <p class="text-3xl font-bold text-slate-900">
                {price.toLocaleString('fr-FR', { style: 'currency', currency })}
              </p>
            )}
          </div>
        )}

        <AffiliateButton
          productId={productId}
          productSlug={Astro.url.pathname}
          merchant={merchant}
          affiliateUrl={affiliateUrl}
          sourcePage={canonical}
        />

        <!-- Disclosure -->
        <p class="text-xs text-slate-400 mt-3">
          * Lien affilié — nous percevons une commission si vous achetez via ce lien, sans surcoût pour vous.
        </p>
      </div>
    </div>

    <!-- Pros / Cons -->
    <div class="grid md:grid-cols-2 gap-6 mb-12">
      <div class="card border-emerald-200">
        <h2 class="font-semibold text-emerald-700 mb-3 flex items-center gap-2">
          <span aria-hidden="true">✓</span> Points forts
        </h2>
        <ul class="space-y-2">
          {pros.map((p) => (
            <li class="flex items-start gap-2 text-slate-700">
              <span class="text-emerald-500 mt-0.5" aria-hidden="true">+</span>{p}
            </li>
          ))}
        </ul>
      </div>
      <div class="card border-red-200">
        <h2 class="font-semibold text-red-700 mb-3 flex items-center gap-2">
          <span aria-hidden="true">✗</span> Points faibles
        </h2>
        <ul class="space-y-2">
          {cons.map((c) => (
            <li class="flex items-start gap-2 text-slate-700">
              <span class="text-red-400 mt-0.5" aria-hidden="true">−</span>{c}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Contenu -->
    <div class="prose max-w-none">
      <slot />
    </div>

    <!-- CTA bas de page -->
    <div class="mt-12 p-6 bg-brand-50 rounded-xl text-center border border-brand-200">
      <p class="text-lg font-semibold text-slate-900 mb-4">Prêt à essayer {title} ?</p>
      <AffiliateButton
        productId={productId}
        productSlug={Astro.url.pathname}
        merchant={merchant}
        affiliateUrl={affiliateUrl}
        sourcePage={canonical}
        position={2}
      />
    </div>
  </div>
</BaseLayout>
