---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — Guide Collagène"
  description="Contactez l'équipe de Guide Collagène pour toute question, partenariat ou signalement."
>
  <div class="max-w-xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-slate-900 mb-4">Contact</h1>
    <p class="text-slate-600 mb-8">
      Pour toute question sur nos analyses, un partenariat ou un signalement d'erreur factuelle :
    </p>
    <a
      href="mailto:contact@guidecollagene.fr"
      class="btn-primary text-base"
    >
      contact@guidecollagene.fr
    </a>
  </div>
</BaseLayout>
